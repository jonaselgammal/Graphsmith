{
  "$defs": {
    "GraphEdge": {
      "description": "One graph edge from source address to destination address.",
      "properties": {
        "from": {
          "title": "From",
          "type": "string"
        },
        "to": {
          "title": "To",
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ],
      "title": "GraphEdge",
      "type": "object"
    },
    "GraphNode": {
      "description": "One graph node.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "op": {
          "title": "Op",
          "type": "string"
        },
        "inputs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Inputs",
          "type": "object"
        },
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "when": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "When"
        },
        "retry": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry"
        },
        "timeout_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timeout Ms"
        }
      },
      "required": [
        "id",
        "op"
      ],
      "title": "GraphNode",
      "type": "object"
    }
  },
  "description": "Graph body from graph.yaml.",
  "properties": {
    "version": {
      "title": "Version",
      "type": "integer"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/GraphNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/GraphEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "outputs": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Outputs",
      "type": "object"
    }
  },
  "required": [
    "version",
    "nodes",
    "edges",
    "outputs"
  ],
  "title": "GraphBody",
  "type": "object"
}

{
  "$defs": {
    "IOField": {
      "description": "Input or output field contract.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "type": {
          "title": "Type"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Description"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "title": "IOField",
      "type": "object"
    },
    "QualityInfo": {
      "description": "Optional skill quality metadata.",
      "properties": {
        "latency_ms_p50": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Latency Ms P50"
        },
        "success_rate": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Success Rate"
        }
      },
      "title": "QualityInfo",
      "type": "object"
    }
  },
  "description": "Top-level skill metadata from skill.yaml.",
  "properties": {
    "id": {
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "description": {
      "title": "Description",
      "type": "string"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/IOField"
      },
      "title": "Inputs",
      "type": "array"
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/IOField"
      },
      "title": "Outputs",
      "type": "array"
    },
    "effects": {
      "items": {
        "type": "string"
      },
      "title": "Effects",
      "type": "array"
    },
    "preconditions": {
      "items": {
        "type": "string"
      },
      "title": "Preconditions",
      "type": "array"
    },
    "postconditions": {
      "items": {
        "type": "string"
      },
      "title": "Postconditions",
      "type": "array"
    },
    "dependencies": {
      "items": {
        "type": "string"
      },
      "title": "Dependencies",
      "type": "array"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "quality": {
      "anyOf": [
        {
          "$ref": "#/$defs/QualityInfo"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "authors": {
      "items": {
        "type": "string"
      },
      "title": "Authors",
      "type": "array"
    },
    "license": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "License"
    },
    "homepage": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Homepage"
    }
  },
  "required": [
    "id",
    "name",
    "version",
    "description",
    "inputs",
    "outputs",
    "effects"
  ],
  "title": "SkillMetadata",
  "type": "object"
}
